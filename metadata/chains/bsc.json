{
  "id": "bsc",
  "name": "Binance Smart Chain",
  "scanner_url_template": "https://bscscan.com/address/{address}",
  "transaction_scanner_url_template": "https://bscscan.com/tx/{transaction}",
  "curve": "secp256k1",
  "address_pipeline": "evm",
  "requires_stake_key": false,
  "address_params": {},
  "public_key_formats": [{
