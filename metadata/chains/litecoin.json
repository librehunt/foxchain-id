{
  "id": "litecoin",
  "name": "Litecoin",
  "scanner_url_template": "https://blockchair.com/litecoin/address/{address}",
  "curve": "secp256k1",
  "address_pipeline": "bitcoin_p2pkh",
  "requires_stake_key": false,
  "address_params": {
    "version_byte": 48
  },
  "public_key_formats": [{
    "encoding": "hex",
    "length_range": [66, 130],
    "prefixes": ["0x"]
  }]
}

