{
  "id": "litecoin",
  "name": "Litecoin",
  "scanner_url_template": "https://blockchair.com/litecoin/address/{address}",
  "transaction_scanner_url_template": "https://litecoinspace.org/tx/{transaction}",
  "curve": "secp256k1",
  "address_pipeline": "bitcoin_p2pkh",
  "requires_stake_key": false,
  "address_params": {
    "version_byte": 48
  },
  "public_key_formats": [
    {
      "encoding": "hex",
      "length_range": [
        66,
        132
      ],
      "prefixes": [
        "0x"
      ]
    }
  ],
  "block_hash_scanner_url_template": "https://litecoinspace.org/block/{block_hash}"
}
