{
  "id": "avalanche",
  "name": "Avalanche",
  "scanner_url_template": "https://routescan.io/avalanche/address/{address}",
  "transaction_scanner_url_template": "https://snowtrace.io/tx/{transaction}",
  "curve": "secp256k1",
  "address_pipeline": "evm",
  "requires_stake_key": false,
  "address_params": {},
  "public_key_formats": [
    {
      "encoding": "hex",
      "length_range": [
        66,
        132
      ],
      "prefixes": [
        "0x"
      ]
    }
  ],
  "block_hash_scanner_url_template": "https://snowtrace.io/block/{block_hash}"
}
