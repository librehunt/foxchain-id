{
  "id": "bitcoin",
  "name": "Bitcoin",
  "scanner_url_template": "https://www.blockchain.com/explorer/addresses/btc/{address}",
  "transaction_scanner_url_template": "https://www.blockchain.com/explorer/transactions/btc/{transaction}",
  "curve": "secp256k1",
  "address_pipeline": "bitcoin_p2pkh",
  "requires_stake_key": false,
  "address_params": {
    "version_byte": 0
  },
  "public_key_formats": [{
    "encoding": "hex",
    "length_range": [66, 132],
    "prefixes": ["0x"]
  }]
}

